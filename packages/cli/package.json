{
  "name": "@codex-switch/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "codex-switch": "./bin/codex-switch.js",
    "cs": "./bin/cs.js"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "dev": "pnpm exec tsx src/index.ts",
    "test": "pnpm exec tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "@codex-switch/shared": "workspace:*",
    "better-sqlite3": "12.9.0",
    "chokidar": "5.0.0",
    "commander": "14.0.3",
    "execa": "9.6.1",
    "get-port": "7.1.0",
    "open": "11.0.0",
    "pino": "10.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13"
  }
}
