{
  "name": "codex-switch",
  "version": "1.0.7",
  "description": "Native Codex account switching with a vault-backed CLI.",
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm --filter @codex-switch/shared build && pnpm -r typecheck",
    "lint": "pnpm exec eslint .",
    "test": "pnpm --filter @codex-switch/shared build && pnpm --filter @codex-switch/shared test && pnpm --filter @codex-switch/cli test",
    "dev:cli": "pnpm --filter @codex-switch/cli dev",
    "prepack": "node ./scripts/prepack.mjs"
  },
  "files": [
    "bin/",
    "packages/cli/dist/",
    "packages/shared/dist/",
    "README.md",
    "CHANGELOG.md"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "bin": {
    "codex-switch": "bin/codex-switch.js",
    "cs": "bin/cs.js"
  },
  "keywords": [
    "codex",
    "cli",
    "oauth",
    "account-switching"
  ],
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "better-sqlite3": "12.9.0",
    "commander": "14.0.3",
    "execa": "9.6.1",
    "pino": "10.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.1",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "prettier": "3.6.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.2"
  }
}
